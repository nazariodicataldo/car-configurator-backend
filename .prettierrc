{
    "plugins": ["@prettier/plugin-php"],
    "useTabs": false,
    "tabWidth": 4,
    "endOfLine": "lf",
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "phpVersion": "8.4",
    "trailingCommaPHP": true,
    "braceStyle": "per-cs",
    "showUnassigned": false
  }
  